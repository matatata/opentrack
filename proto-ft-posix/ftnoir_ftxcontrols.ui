   </rect>
  </property>
  <property name="windowTitle">
   <string>Opentrack</string>
  </property>
  <property name="windowIcon">
   <iconset resource="ftx-protocol.qrc">
    <normaloff>:/images/freetrack.png</normaloff>:/images/freetrack.png</iconset>
  </property>
  <property name="layoutDirection">
   <enum>Qt::LayoutDirection::LeftToRight</enum>
  </property>
  <property name="autoFillBackground">
   <bool>false</bool>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QGroupBox" name="groupBox">
     <property name="title">
      <string>freetrackX 2.0 Enhanced</string>
     </property>
     <layout class="QGridLayout" name="gridLayout_2">
      <item row="1" column="0">
       <widget class="QLabel" name="label">
        <property name="text">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;This module should be used with native software or software run via &lt;a href=&quot;https://www.winehq.org&quot;&gt;&lt;span style=&quot; text-decoration: underline; color:#1f9b5d;&quot;&gt;Wine&lt;/span&gt;&lt;/a&gt;.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Native&lt;/span&gt;&lt;/p&gt;&lt;p&gt;This module is aimed for native clients using opentrack's &lt;span style=&quot; font-weight:700;&quot;&gt;opentrackclient library&lt;/span&gt;. As an example Opentrack's &lt;span style=&quot; font-weight:700;&quot;&gt;X-Plane&lt;/span&gt; plugin now uses this library.&lt;br/&gt;This approach resembles how freetrack and other popular headtracking solutions are integrated in games on the Windows platforms.&lt;br/&gt;As far as I know there are not many options neither on macOS nor Linux which is why I created it in order to invite developers&lt;br/&gt;to bring native headtracking to native macOS and Linux games as well. I kept the name freetrack to honor its effort and&lt;br/&gt;to point out its origin although it's really tied to Opentrack being a popular opensource headtracking solution.&lt;/p&gt;&lt;p&gt;I invite developers to use it to integrate their products with opentrack.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Games run via Wine&lt;/span&gt;&lt;/p&gt;&lt;p&gt;The module can also be used for the usage with windows games running on macOS or Linux via Wine based solutions such as&lt;br/&gt;&lt;a href=&quot;https://www.codeweavers.com/crossover&quot;&gt;&lt;span style=&quot; text-decoration: underline; color:#1f9b5d;&quot;&gt;CrossOver&lt;/span&gt;&lt;/a&gt; or Steam's Proton on Linux. Use it in conjunction with opentrack's &lt;a href=&quot;https://github.com/matatata/opentrack/tree/master/wine-bridge&quot;&gt;&lt;span style=&quot; text-decoration: underline; color:#1f9b5d;&quot;&gt;Wine-Bridge&lt;/span&gt;&lt;/a&gt; which is an alternative Wine-integration.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="sizePolicy">
      <sizepolicy hsizetype="Expanding" vsizetype="Maximum">
       <horstretch>0</horstretch>
       <verstretch>0</verstretch>
      </sizepolicy>
     </property>
     <property name="standardButtons">
      <set>QDialogButtonBox::StandardButton::Close</set>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
